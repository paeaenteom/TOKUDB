{
  "cleanUrls": true,
  "regions": ["hnd1"],
  "rewrites": [
    { "source": "/i/(.*)", "destination": "/api/img?p=$1" },
    { "source": "/summ/(.*)", "destination": "/api/char?p=$1" },
    { "source": "/IMG", "destination": "/DB/search" },
    { "source": "/IMG/(.*)", "destination": "/DB/search" },
    { "source": "/DB/(.*)", "destination": "/DB" },
    { "source": "/wapon", "destination": "/WAPON" },
    { "source": "/wapon/(.*)", "destination": "/WAPON" },
    { "source": "/unpack", "destination": "/UNPACK" },
    { "source": "/unpack/(.*)", "destination": "/UNPACK" },
    { "source": "/dal", "destination": "/DAL" },
    { "source": "/dal/(.*)", "destination": "/DAL" },
    { "source": "/sim/(.*)", "destination": "/sim" }
  ]
}
